      "recipe": "recipes/claude-code.md",
      "support": "trusted_agent_install",
      "userScopeConfiguration": "~/.claude.json"
    },
    "cursor": {
      "recipe": "recipes/cursor.md",
      "support": "ai_assisted_unverified",
      "userScopeConfiguration": "~/.cursor/mcp.json"
